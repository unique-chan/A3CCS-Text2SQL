DB_URL=sqlite:///outputs/arma_sql/state.db
JSON_DIR=outputs/arma_json
OUT_DIR=results

MAX_REPAIR_ATTEMPTS=3
MAX_STEPS=10
MAX_SAME_SQL_REPEATS=1
MAX_ROWS=50

BLOCK_NON_READONLY_SQL=1
TREAT_REFUSAL_RESULT_AS_ERROR=1

INSTRUCTION_PATH=text2sql_prompts/schema_instruction_main.md
TEXT2SQL_PROMPT_PATH=text2sql_prompts/system_text2sql.md
REPAIR_PROMPT_PATH=text2sql_prompts/system_repair.md

LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=http://172.26.49.151:8000/v1
OPENAI_MODEL=openai/gpt-oss-120b
# OPENAI_BASE_URL=http://172.26.19.30:8000/v1
# OPENAI_MODEL=./gpt-oss-20b
OPENAI_TEMPERATURE=0.1
