DB_URL=sqlite:///outputs/arma_sql/state.db
JSON_DIR=outputs/arma_json
OUT_DIR=results

MAX_REPAIR_ATTEMPTS=3
MAX_STEPS=10
MAX_SAME_SQL_REPEATS=1
MAX_ROWS=50

BLOCK_NON_READONLY_SQL=1

SCHEMA_INSTRUCTION_PATH=text2sql_prompts/schema_instruction_main.md
TEXT2SQL_PROMPT_PATH=text2sql_prompts/system_text2sql.md
REPAIR_PROMPT_PATH=text2sql_prompts/system_repair.md

ENABLE_SEMANTIC_CHECK=0
SEMANTIC_CHECK_PROMPT_PATH=text2sql_prompts/system_semantic_check.md
SEMANTIC_REPAIR_PROMPT_PATH=text2sql_prompts/system_semantic_repair.md

REWRITE_REFLECT_PROMPT_PATH=text2sql_prompts/system_rewrite_reflect.md
REWRITE_SQL_PROMPT_PATH=text2sql_prompts/system_rewrite_sql.md
REWRITE_INTENT_PROMPT_PATH=text2sql_prompts/system_rewrite_intent.md
SQL_CHEAT_GENERAL_PATH=text2sql_prompts/SQL_cheating_sheets/general.md

LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=http://172.26.49.151:8000/v1
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_TEMPERATURE=0.1
